rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Checks if the user is authenticated and is registered in the admins collection
    // Note: Store admin records where the document ID is the user's lowercase email address
    // Example: collection "admins", document ID: "admin@mspbharat.com" -> { role: "admin" }
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    
    // Admins Collection Rules
    match /admins/{emailId} {
      allow read: if request.auth != null; // logged in users can check their own role
      allow write: if false; // manage admin seats directly through Firebase Console for safety
    }
    
    // Products Collection Rules
    match /products/{productId} {
      allow read: if true; // anyone can view catalog
      allow write: if isAdmin(); // only admins can add, update or delete products
    }
    
    // Categories Division Rules
    match /categories/{categoryId} {
      allow read: if true; // anyone can view divisions
      allow write: if isAdmin(); // only admins can manage divisions
    }
    
    // Enquiries Collection Rules
    match /enquiries/{enquiryId} {
      allow create: if true; // public customers can submit cart checkout orders
      allow read, update, delete: if isAdmin(); // only admins can manage and track status
    }
  }
}
