{
  "version": 2,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api"
    },
    {
      "source": "/robots.txt",
      "destination": "/api"
    },
    {
      "source": "/product-details",
      "destination": "/api"
    },
    {
      "source": "/product-details.html",
      "destination": "/api"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "cleanUrls": true
}
